#!/usr/bin/env bash
# ov_map: 执行 ontology-mapper 进行数据模式映射

set -e

SOURCE=""
SCHEMA=""
ONTOLOGY=""
OUTPUT=""
VERBOSE=""

while [[ $# -gt 0 ]]; do
  case $1 in
    --source)
      SOURCE="$2"
      shift 2
      ;;
    --schema)
      SCHEMA="$2"
      shift 2
      ;;
    --ontology)
      ONTOLOGY="$2"
      shift 2
      ;;
    --output)
      OUTPUT="$2"
      shift 2
      ;;
    --verbose|-v)
      VERBOSE="1"
      shift
      ;;
    *)
      echo "未知参数: $1"
      exit 1
      ;;
  esac
done

if [[ -z "$SOURCE" || -z "$SCHEMA" || -z "$ONTOLOGY" || -z "$OUTPUT" ]]; then
  echo "用法: ov_map --source <文件> --schema <文件> --ontology <文件> --output <文件>"
  exit 1
fi

# 确保输出目录存在
mkdir -p "$(dirname "$OUTPUT")"

# 调用内置的 ontology-mapper-cli（相对路径）
CLI_PATH="$(dirname "$0")/ontology-mapper-cli"
if [[ ! -x "$CLI_PATH" ]]; then
  chmod +x "$CLI_PATH"
fi

CMD="$CLI_PATH --source \"$SOURCE\" --schema \"$SCHEMA\" --ontology \"$ONTOLOGY\" --output \"$OUTPUT\""

if [[ -n "$VERBOSE" ]]; then
  echo "执行: $CMD" >&2
fi

eval $CMD
