#!/usr/bin/env bash
# ov_pipeline: 一键执行完整流程（映射 → 存储 → 索引）

set -e

SOURCE=""
SCHEMA=""
ONTOLOGY=""
NAME=""
TAGS=""
OUTPUT_DIR="$HOME/.openclaw/viking/resources/mapped"
VERBOSE=""
SV_WORKSPACE="${SV_WORKSPACE:-$HOME/.openclaw/viking}"

while [[ $# -gt 0 ]]; do
  case $1 in
    --source)
      SOURCE="$2"
      shift 2
      ;;
    --schema)
      SCHEMA="$2"
      shift 2
      ;;
    --ontology)
      ONTOLOGY="$2"
      shift 2
      ;;
    --name)
      NAME="$2"
      shift 2
      ;;
    --tags)
      TAGS="$2"
      shift 2
      ;;
    --output-dir)
      OUTPUT_DIR="$2"
      shift 2
      ;;
    --verbose|-v)
      VERBOSE="1"
      shift
      ;;
    *)
      echo "未知参数: $1" >&2
      exit 1
      ;;
  esac
done

if [[ -z "$SOURCE" || -z "$SCHEMA" || -z "$ONTOLOGY" ]]; then
  echo "用法: $0 --source <文件> --schema <文件> --ontology <文件> --name <名称> [--tags <标签>] [--output-dir <目录>]" >&2
  exit 1
fi

mkdir -p "$OUTPUT_DIR"

TIMESTAMP=$(date +%Y%m%d_%H%M%S)
if [[ -n "$NAME" ]]; then
  SAFE_NAME=$(echo "$NAME" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/_/g')
  OUTPUT_JSON="$OUTPUT_DIR/${SAFE_NAME}_$TIMESTAMP.json"
else
  OUTPUT_JSON="$OUTPUT_DIR/automatic_$TIMESTAMP.json"
fi

VIKING_MD="${OUTPUT_JSON%.json}.md"
VIKING_URI="resources/mapped/$(basename "$VIKING_MD")"

echo "=== Ontology-Viking 管道 ===" >&2
echo "源: $SOURCE" >&2
echo "输出: $OUTPUT_JSON" >&2

# 步骤 1: 映射
echo "步骤 1/3: 映射数据..." >&2
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
"$SCRIPT_DIR/ov_map" --source "$SOURCE" --schema "$SCHEMA" --ontology "$ONTOLOGY" --output "$OUTPUT_JSON" ${VERBOSE:+--verbose}
if [[ $? -ne 0 ]]; then
  echo "映射失败" >&2
  exit 1
fi

# 读取映射结果
MAPPINGS_JSON=$(cat "$OUTPUT_JSON")
TOTAL=$(echo "$MAPPINGS_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin)['total_fields'])" 2>/dev/null || echo "0")
MAPPED=$(echo "$MAPPINGS_JSON" | python3 -c "import sys,json; print(json.load(sys.stdin)['mapped_count'])" 2>/dev/null || echo "0")

# 生成 Markdown 内容（使用匿名管道避免花括号扩展问题）
{
  echo "# ${NAME:-Untitled}"
  echo ""
  echo "## 映射结果"
  echo ""
  echo "- **总字段数:** $TOTAL"
  echo "- **已映射:** $MAPPED"
  if [[ $TOTAL -gt 0 ]]; then
    PERCENT=$(python3 -c "print(round($MAPPED/$TOTAL*100,1))" 2>/dev/null || echo "0")
    echo "- **覆盖率:** ${PERCENT}%"
  fi
  echo ""
  echo "### 详细映射"
  echo ""
  python3 -c "
import sys, json
data = json.loads(sys.stdin.read())
for m in data['mappings']:
    if 'target' in m:
        print(f\"- **{m['field']}**: {m['source']} => \\\`{m['target']}\\\` (confidence: {m['confidence']})\")
    else:
        print(f\"- **{m['field']}**: {m['source']} => [未映射]\")
" <<< "$MAPPINGS_JSON"
  if [[ -n "$TAGS" ]]; then
    echo ""
    echo "**Tags:** $TAGS"
  fi
  echo ""
  echo "---"
  echo "*Generated by ontology-viking-workflow*"
} > "$VIKING_MD"

echo "  已生成 Markdown: $VIKING_MD" >&2

# 写入 Viking
export SV_WORKSPACE
cat "$VIKING_MD" | python3 -c "
import sys, json, os
content = sys.stdin.read()
uri = 'viking://$VIKING_URI'
payload = {'uri': uri, 'content': content}
print(json.dumps(payload))
" | /home/xlous/.openclaw/skills/simple-viking/tools/sv_write

if [[ $? -ne 0 ]]; then
  echo "存储到 Viking 失败" >&2
  exit 1
fi

echo "  存储到: viking://$VIKING_URI" >&2

# 更新索引
echo "步骤 3/3: 更新索引..." >&2
DIR_PATH=$(dirname "$VIKING_URI" | sed 's/^viking:\/\///')
/home/xlous/.openclaw/skills/simple-viking/tools/sv_update_layers "viking://$DIR_PATH/" 2>/dev/null || true

echo "=== 完成 ===" >&2
echo "{\"status\":\"ok\",\"message\":\"数据处理完成\",\"viking_uri\":\"viking://$VIKING_MD\"}"
